# 基于大模型的个性化资源生成与学习多智能体系统 - 环境变量配置模板
# 复制为 .env 后填写真实值

# ========== 应用基础配置 ==========
APP_NAME=SmartLearning-MAS
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ========== 科大讯飞星火大模型 API ==========
# 申请地址: https://xinghuo.xfyun.cn/
XINGHUO_APP_ID=your_app_id_here
XINGHUO_API_KEY=your_api_key_here
XINGHUO_API_SECRET=your_api_secret_here
XINGHUO_MODEL_VERSION=v3.5

# ========== 火山方舟 DeepSeek API (当前主用) ==========
# 申请地址: https://console.volcengine.com/ark/
VOLCES_API_KEY=ark-8ecadcf3-5a8e-4b9d-80a0-3ebdda1d2c59-888c0
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCES_MODEL=deepseek-v3-2-251201

# ========== OpenAI API (备选方案) ==========
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ========== 数据库配置 ==========
# MySQL
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/smart_learning?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# ========== 向量数据库配置 ==========
# Chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=knowledge_base

# FAISS (作为备选或辅助)
FAISS_INDEX_PATH=./data/faiss_index

# ========== Embedding 模型配置 ==========
# 本地模型路径或 HuggingFace 模型名
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# ========== 知识库配置 ==========
KNOWLEDGE_BASE_DIR=./knowledge_base
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ========== 多智能体配置 ==========
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
