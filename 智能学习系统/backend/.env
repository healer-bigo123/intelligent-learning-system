# 基于大模型的个性化资源生成与学习多智能体系统 - 环境变量配置

# ========== 应用基础配置 ==========
APP_NAME=SmartLearning-MAS
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ========== LLM 厂商选择 ==========
# 可选值：volces(火山方舟)、xinghuo(讯飞星火)、openai
# 修改此项即可切换大模型，无需改动代码
LLM_PROVIDER=volces

# ========== 火山方舟 DeepSeek API (当前主用) ==========
VOLCES_API_KEY=ark-8ecadcf3-5a8e-4b9d-80a0-3ebdda1d2c59-888c0
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCES_MODEL=deepseek-v3-2-251201

# ========== 科大讯飞星火大模型 API (备用) ==========
# 申请地址：https://www.xfyun.cn/doc/spark/Web.html
XINGHUO_APP_ID=
XINGHUO_API_KEY=
XINGHUO_API_SECRET=
XINGHUO_BASE_URL=https://spark-api-open.xf-yun.com/v1
XINGHUO_DOMAIN=generalv3.5
XINGHUO_MODEL=generalv3.5

# ========== OpenAI API (备选方案) ==========
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ========== 数据库配置 ==========
# MySQL 数据库连接（使用 pymysql 驱动）
DATABASE_URL=mysql+pymysql://root:031903@localhost:3306/smart_learning?charset=utf8mb4

# SQLite 备用配置（无需额外安装）
# DATABASE_URL=sqlite:///./data/smart_learning.db

# Redis (可选)
REDIS_URL=

# ========== 向量数据库配置 ==========
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=knowledge_base
FAISS_INDEX_PATH=./data/faiss_index

# ========== Embedding 模型配置 ==========
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# ========== 知识库配置 ==========
KNOWLEDGE_BASE_DIR=./knowledge_base
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ========== 多智能体配置 ==========
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ========== 向量存储配置 ==========
# true = 使用简化版（无需下载模型，推荐开发阶段使用）
# false = 使用完整版（需要下载 HuggingFace 模型）
USE_SIMPLE_VECTOR=true
